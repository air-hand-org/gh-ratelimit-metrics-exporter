{
  "extends": [
    "github>aquaproj/aqua-renovate-config#2.12.0",
    "helpers:pinGitHubActionDigests",
    "config:recommended",
    ":semanticCommits",
  ],
  "prConcurrentLimit": 10,
  "enabledManagers": [
    "custom.regex", // aqua
    "mise",
    "github-actions",
    "gomod",
  ],
  labels: ['dependencies'],
  assigneesFromCodeOwners: true,
  packageRules: [
    {
      matchUpdateTypes: ['major'],
      addLabels: ['major']
    },
    {
      matchUpdateTypes: ['minor'],
      addLabels: ['minor'],
      automerge: true,
    },
    {
      matchUpdateTypes: ['patch'],
      addLabels: ['patch'],
      automerge: true,
    },
    {
      description: 'Update mise Go version with go.mod Go directive',
      matchManagers: ['mise'],
      matchDepNames: ['go'],
      groupName: 'Go',
      groupSlug: 'go',
      semanticCommitType: 'fix',
      semanticCommitScope: 'deps',
    },
    {
      description: 'Update go.mod Go directive with mise Go version',
      matchManagers: ['gomod'],
      matchDepNames: ['go'],
      matchDepTypes: ['golang'],
      groupName: 'Go',
      groupSlug: 'go',
      rangeStrategy: 'bump',
      semanticCommitType: 'fix',
      semanticCommitScope: 'deps',
    },
    {
      "matchManagers": ["gomod"],
      "postUpdateOptions": ["gomodTidy", "gomodUpdateImportPaths"],
    },
  ],
  mise: {
    managerFilePatterns: [
      '(^|/)\\.?mise\\.toml$',
      '(^|/)\\.?mise/config\\.toml$',
      '(^|/)\\.?mise/config.*\\.toml$'
    ]
  },
  rebaseWhen: "behind-base-branch",
  minimumReleaseAge: "3 days",
}
